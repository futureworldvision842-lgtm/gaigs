rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    function owns(uid) { return signedIn() && request.auth.uid == uid; }
    function mediaUpload() {
      return request.resource.size < 100 * 1024 * 1024
        && request.resource.contentType.matches('(image|video)/.*');
    }
    function memberOf(communityId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/communities/$(communityId)/members/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/communities/$(communityId)/members/$(request.auth.uid)).data.status == 'active';
    }
    function adminOf(communityId) {
      return memberOf(communityId)
        && firestore.get(/databases/(default)/documents/communities/$(communityId)/members/$(request.auth.uid)).data.role in ['admin','committee'];
    }
    function canReadScope(scope, scopeId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && (
          scope == 'global'
          || (scope == 'country' && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.country == scopeId)
          || (scope == 'city' && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.city == scopeId)
          || (scope == 'society' && memberOf(scopeId))
        );
    }

    match /users/{uid}/posts/{postId}/{fileName} {
      allow write: if owns(uid) && mediaUpload();
      allow read: if firestore.exists(/databases/(default)/documents/posts/$(postId))
        && canReadScope(firestore.get(/databases/(default)/documents/posts/$(postId)).data.scope, firestore.get(/databases/(default)/documents/posts/$(postId)).data.scopeId);
    }
    match /users/{uid}/emergencies/{emergencyId}/{fileName} {
      allow write: if owns(uid) && mediaUpload();
      allow read: if firestore.exists(/databases/(default)/documents/emergencies/$(emergencyId))
        && canReadScope(firestore.get(/databases/(default)/documents/emergencies/$(emergencyId)).data.scope, firestore.get(/databases/(default)/documents/emergencies/$(emergencyId)).data.scopeId);
    }
    match /users/{uid}/{allPaths=**} {
      allow read: if owns(uid);
      allow write: if owns(uid) && mediaUpload();
    }
    match /evidence/{communityId}/{uid}/{allPaths=**} {
      allow read: if owns(uid) || adminOf(communityId);
      allow write: if owns(uid)
        && request.resource.size < 100 * 1024 * 1024
        && request.resource.contentType.matches('(image|video|application/pdf).*');
    }
    match /projects/{projectId}/milestones/{milestoneId}/{fileName} {
      allow read: if firestore.exists(/databases/(default)/documents/projects/$(projectId))
        && canReadScope(firestore.get(/databases/(default)/documents/projects/$(projectId)).data.scope, firestore.get(/databases/(default)/documents/projects/$(projectId)).data.scopeId);
      allow create: if signedIn()
        && firestore.exists(/databases/(default)/documents/projects/$(projectId))
        && canReadScope(firestore.get(/databases/(default)/documents/projects/$(projectId)).data.scope, firestore.get(/databases/(default)/documents/projects/$(projectId)).data.scopeId)
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType.matches('(image|video)/.*|application/pdf');
      allow update, delete: if false;
    }
    match /kyc/{uid}/{allPaths=**} { allow read, write: if false; }
  }
}
